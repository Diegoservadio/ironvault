{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowS3Operations",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::pmi-backup-airgap-2024",
        "arn:aws:s3:::pmi-backup-airgap-2024/*"
      ]
    },
    {
      "Sid": "DenyDeleteOperations",
      "Effect": "Deny",
      "Action": [
        "s3:DeleteObject",
        "s3:DeleteObjectVersion",
        "s3:DeleteBucket",
        "s3:BypassGovernanceRetention"
      ],
      "Resource": [
        "arn:aws:s3:::pmi-backup-airgap-2024",
        "arn:aws:s3:::pmi-backup-airgap-2024/*"
      ]
    }
  ]
}
